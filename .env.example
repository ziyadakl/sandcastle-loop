# Sandcastle multi-provider keys.
# Copy to .env and fill in the real values. .env is gitignored.
#
# ANTHROPIC_API_KEY is only needed if you do NOT have a Claude Pro/Max
# subscription on this machine. With a subscription, the `claude` CLI uses
# its own OAuth credentials at ~/.claude/credentials and ignores this var.
ANTHROPIC_API_KEY=

# Kimi (kimi.com Moderato plan or higher).
# Endpoint: https://api.kimi.com/coding/
# Model ID used by --provider kimi: kimi-for-coding
KIMI_API_KEY=

# GLM (z.ai Coding Plan, any tier).
# Endpoint: https://api.z.ai/api/anthropic
# Model ID used by --provider glm: glm-4.6
GLM_API_KEY=
