.env
logs/
worktrees/
# Per-machine multi-host registry: it holds repoPaths correct for ONE machine, so
# tracking it shipped this repo's paths into every consumer. Seed from
# hosts.example.json instead. Full rationale: docs/adr/0022.
hosts.json
.restart-remaining
.loop.lock
.sandbox-flag
status.json
.status.json.tmp-*
# Foreign package-manager lockfiles must never be tracked here: an untracked
# lockfile that drifts onto integration-candidate can block the final
# fast-forward promotion (audit issue #4).
pnpm-lock.yaml
yarn.lock
package-lock.json
