# Sandcastle environment template.
#
# ===========================================================================
# ON A LOCAL MAC WITH A CLAUDE PRO/MAX SUBSCRIPTION: YOU NEED NOTHING HERE.
# Every key below is OPTIONAL — leave them all blank and run. The default
# models are all Claude (see models.ts) and use the `claude` CLI's own login;
# `gh` is mounted from your host auth. Only fill a key in if a comment below
# says your specific setup needs it (a non-Claude provider, a VPS with no
# `claude login`, or drizzle migrations).
# ===========================================================================
#
# Two valid locations (orchestrator reads both; project-local wins):
#   1. <project-root>/.env       — per-project override
#   2. ~/.config/sandcastle/.env — host-level default, shared across every
#                                  project and worktree on this machine.
#                                  Recommended for KIMI/GLM/Anthropic keys
#                                  you want to set once.
#
# Override the host-level path with `$SANDCASTLE_ENV_FILE=...` if you need
# a custom layout (e.g. piping from 1Password / sops).
#
# Do NOT commit a real .env — `.sandcastle/.gitignore` excludes it.

# ---------------------------------------------------------------------------
# Kimi (kimi.com) — OPTIONAL. The default models are all Claude
# (models.ts), so leave this empty unless you explicitly pass
# `--provider kimi` or set a kimi-* model id. Only then is it required.
# ---------------------------------------------------------------------------
KIMI_API_KEY=

# ---------------------------------------------------------------------------
# GLM (z.ai Coding Plan) — only required if you pass `--provider glm` or use
# a glm-* model id. Safe to leave empty otherwise.
# ---------------------------------------------------------------------------
GLM_API_KEY=

# ---------------------------------------------------------------------------
# Anthropic — only required if `claude auth status` doesn't already work on
# this host (e.g. a VPS where you haven't run `claude login`). On a local
# Mac with a Pro/Max subscription, leave this empty; the orchestrator uses
# the claude CLI's OAuth credentials directly.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# GitHub — required so `gh issue list / view / edit` works inside the
# sandbox for the planner / implementer / reviewer / merger prompts.
# A `gh auth login` token in ~/.config/gh on the host is mounted into the
# sandbox by `docker()`, but providing GH_TOKEN here is also accepted.
# ---------------------------------------------------------------------------
GH_TOKEN=

# ---------------------------------------------------------------------------
# Postgres — used by the host-side migration auto-applier
# (src/migrations/drizzle-applier.ts) between implementer and reviewer phases.
# Point this at the dev database that mirrors the schema the issue is
# changing. Optional but strongly recommended for any UI / integration story
# whose tests depend on a current schema.
# ---------------------------------------------------------------------------
DATABASE_URL=
