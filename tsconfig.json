{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "outDir": "dist",
    "declaration": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/**/*", "tests/**/*", "tools/**/*", ".sandcastle/**/*.mts", ".sandcastle/**/*.ts", "bin/**/*.mts"],
  "exclude": ["archive/**"]
}
